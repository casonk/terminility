<mxGraphModel>
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- Title -->
    <mxCell id="title" value="terminility Repository Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="20" width="1400" height="40" as="geometry" />
    </mxCell>

    <!-- ── Layer Stack ─────────────────────────────────────────────── -->
    <mxCell id="layer_group" value="Layer Stack" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="30" y="80" width="580" height="560" as="geometry" />
    </mxCell>

    <mxCell id="L1" value="1) Installation Layer&#xa;• install.sh&#xa;• detects package manager (apt/dnf/pacman/brew/zypper)&#xa;• installs tmux, clones/updates TPM&#xa;• backs up existing ~/.tmux.conf&#xa;• runs TPM headlessly to install plugins&#xa;• invokes sessions.sh&#xa;• wires alias source guard into ~/.bashrc / ~/.zshrc" style="rounded=1;whiteSpace=wrap;align=left;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacingLeft=8;" vertex="1" parent="layer_group">
      <mxGeometry x="20" y="50" width="540" height="110" as="geometry" />
    </mxCell>

    <mxCell id="L2" value="2) Configuration Layer&#xa;• tmux.conf  →  ~/.tmux.conf&#xa;• 256-color + true-color, mouse, 50k history, base-index 1&#xa;• intuitive split/nav bindings + reload key (prefix+r)&#xa;• TPM plugins: tmux-sensible, tmux-resurrect, tmux-continuum&#xa;• auto-save every 15 min, auto-restore on server start" style="rounded=1;whiteSpace=wrap;align=left;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacingLeft=8;" vertex="1" parent="layer_group">
      <mxGeometry x="20" y="185" width="540" height="95" as="geometry" />
    </mxCell>

    <mxCell id="L3" value="3) Session Management Layer&#xa;• sessions.sh&#xa;• scans GIT_BASE (default: /mnt/4tb-m2/git) for .git dirs&#xa;• derives tmux-safe session name  (/ → -,  spaces/dots → -)&#xa;• creates sessions idempotently (skips existing)&#xa;• ensures tmux server is running before creation" style="rounded=1;whiteSpace=wrap;align=left;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacingLeft=8;" vertex="1" parent="layer_group">
      <mxGeometry x="20" y="305" width="540" height="95" as="geometry" />
    </mxCell>

    <mxCell id="L4" value="4) Alias Layer&#xa;• writes ~/.terminility_aliases  (regenerated atomically each run)&#xa;• one alias per session:  tmux new-session -A -s &lt;name&gt; -c &lt;path&gt;&#xa;  (-A: attach or create;  -c: start in repo root)&#xa;• install.sh adds source guard to shell RCs (idempotent)" style="rounded=1;whiteSpace=wrap;align=left;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacingLeft=8;" vertex="1" parent="layer_group">
      <mxGeometry x="20" y="425" width="540" height="95" as="geometry" />
    </mxCell>

    <!-- Layer arrows -->
    <mxCell id="a_L1L2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="L1" target="L2" parent="layer_group">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a_L2L3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="L2" target="L3" parent="layer_group">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a_L3L4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="L3" target="L4" parent="layer_group">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ── Source Files ────────────────────────────────────────────── -->
    <mxCell id="src_group" value="Source Files (tracked)" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="660" y="80" width="320" height="280" as="geometry" />
    </mxCell>

    <mxCell id="S1" value="install.sh&#xa;Full install orchestrator" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="src_group">
      <mxGeometry x="20" y="50" width="280" height="45" as="geometry" />
    </mxCell>
    <mxCell id="S2" value="sessions.sh&#xa;Repo scanner + session creator + alias generator" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="src_group">
      <mxGeometry x="20" y="110" width="280" height="45" as="geometry" />
    </mxCell>
    <mxCell id="S3" value="tmux.conf&#xa;Tmux configuration source" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="src_group">
      <mxGeometry x="20" y="170" width="280" height="45" as="geometry" />
    </mxCell>
    <mxCell id="S4" value="docs/&#xa;contributor-architecture-blueprint.md&#xa;diagrams/repo-architecture.{puml,drawio}" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="src_group">
      <mxGeometry x="20" y="220" width="280" height="45" as="geometry" />
    </mxCell>

    <!-- ── External Inputs ───────────────────────────────────────────── -->
    <mxCell id="ext_group" value="External Inputs" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="660" y="400" width="320" height="240" as="geometry" />
    </mxCell>

    <mxCell id="E1" value="/mnt/4tb-m2/git/**/.git&#xa;git repositories on disk&#xa;(GIT_BASE, overridable via env)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="ext_group">
      <mxGeometry x="20" y="50" width="280" height="50" as="geometry" />
    </mxCell>
    <mxCell id="E2" value="System package manager&#xa;apt / dnf / pacman / brew / zypper&#xa;(auto-detected)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="ext_group">
      <mxGeometry x="20" y="115" width="280" height="50" as="geometry" />
    </mxCell>
    <mxCell id="E3" value="GitHub (TPM + plugins)&#xa;tmux-plugins/tpm&#xa;tmux-resurrect  •  tmux-continuum" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="ext_group">
      <mxGeometry x="20" y="178" width="280" height="50" as="geometry" />
    </mxCell>

    <!-- ── Runtime Artifacts ─────────────────────────────────────────── -->
    <mxCell id="rt_group" value="Runtime Artifacts (untracked)" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=14;" vertex="1" parent="1">
