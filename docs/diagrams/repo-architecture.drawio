    <mxCell id="R2" value="~/.tmux/plugins/tpm/  —  TPM clone" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="rt_group">
      <mxGeometry x="20" y="105" width="300" height="40" as="geometry" />
    </mxCell>
    <mxCell id="R3" value="~/.tmux/plugins/tmux-resurrect/&#xa;~/.tmux/plugins/tmux-continuum/" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="rt_group">
      <mxGeometry x="20" y="160" width="300" height="50" as="geometry" />
    </mxCell>
    <mxCell id="R4" value="~/.tmux/resurrect/  —  session save files" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="rt_group">
      <mxGeometry x="20" y="225" width="300" height="40" as="geometry" />
    </mxCell>
    <mxCell id="R5" value="~/.terminility_aliases&#xa;generated alias file  (regenerated each run)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="rt_group">
      <mxGeometry x="20" y="280" width="300" height="50" as="geometry" />
    </mxCell>
    <mxCell id="R6" value="~/.bash_aliases  /  ~/.zshrc&#xa;source guard added by install.sh" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="rt_group">
      <mxGeometry x="20" y="345" width="300" height="50" as="geometry" />
    </mxCell>

    <!-- ── Data Flow label ──────────────────────────────────────────── -->
    <mxCell id="flow_label" value="Data Flow&#xa;/mnt/4tb-m2/git/**/.git&#xa;  → sessions.sh&#xa;  → tmux sessions (idempotent)&#xa;  → ~/.terminility_aliases&#xa;  → ~/.bash_aliases / ~/.zshrc&#xa;  → aliases active in every new shell" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="1030" y="670" width="340" height="130" as="geometry" />
    </mxCell>

