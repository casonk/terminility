    <mxCell id="R1" value="~/.tmux.conf&#xa;deployed config" style="shape=mxgraph.cisco.sites.generic_building;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="rt_group">
